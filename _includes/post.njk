---
layout: base.njk
---
{% set accent = project %}

<div class="wayfinding">
  <a class="back-link" href="/devlog/">← back to the devlog</a>
</div>

<header class="bp-article">
  <p class="bp-meta-row">
    <span class="type-pill">{{ type | capitalize }}</span>
    <span><time datetime="{{ date | isoDate }}">{{ date | monthYear }}</time></span>
    {% if read_time %}<span class="sep">·</span><span>{{ read_time }} min read</span>{% endif %}
    {% if project %}
      <span class="sep">·</span>
      <span class="planet-mark">
        <span class="dot" style="background: {{ project | projectColor }};"></span>
        from {{ project | projectName }}
      </span>
    {% endif %}
  </p>
  <h1>{{ title }}</h1>
  {% if dek %}<p class="bp-dek">{{ dek }}</p>{% endif %}
  <div class="bp-byline">
    <span class="avatar" aria-hidden="true">A.</span>
    <span class="who">
      Addison<br/>
      <span>Posted <time datetime="{{ date | isoDate }}">{{ date | shortDate }}</time></span>
    </span>
  </div>
</header>

{% if youtube_id %}
<div class="bp-article">
  <div class="bp-youtube">
    <iframe
      src="https://www.youtube.com/embed/{{ youtube_id }}"
      title="{{ title }} — companion video"
      frameborder="0"
      allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
      allowfullscreen></iframe>
  </div>
</div>
{% endif %}

<article class="bp-body">
  {{ content | safe }}
</article>

<p class="bp-end" aria-hidden="true">✦</p>

{% if tags and tags.length %}
<div class="bp-tags">
  <span class="lbl">Tagged</span>
  {% for tag in tags %}
    {% if tag != "posts" %}
      <span class="bp-tag">{{ tag }}</span>
    {% endif %}
  {% endfor %}
</div>
{% endif %}

{# Previous/next navigation within the posts collection.
   Note: with newest-first sorting, Eleventy's "previous item" is actually
   newer (earlier in the array). We swap so the labels match reading
   convention — "← Previous" goes to an older post, "Next →" to a newer one. #}
{% set newerPost = collections.posts | getPreviousCollectionItem(page) %}
{% set olderPost = collections.posts | getNextCollectionItem(page) %}
{% if olderPost or newerPost %}
<nav class="bp-postnav" aria-label="Post navigation">
  {% if olderPost %}
  <a href="{{ olderPost.url }}" class="left">
    <p class="lbl">← Previous</p>
    <h4>{{ olderPost.data.title }}</h4>
  </a>
  {% else %}<span></span>{% endif %}

  {% if newerPost %}
  <a href="{{ newerPost.url }}" class="right">
    <p class="lbl">Next →</p>
    <h4>{{ newerPost.data.title }}</h4>
  </a>
  {% else %}<span></span>{% endif %}
</nav>
{% endif %}
