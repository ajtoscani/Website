{# Reusable star field SVG.
   Renders a fixed pattern of background stars with twinkle animation.
   Usage:
     {% from "partials/stars.njk" import starfield %}
     {{ starfield() }}
#}
{% macro starfield() %}
<svg width="100%" height="100%" viewBox="0 0 600 280" preserveAspectRatio="xMidYMid slice" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
  <g fill="#FFFFFF" opacity="0.7">
    <circle cx="40" cy="40" r="0.8" class="twinkle-1"/>
    <circle cx="140" cy="20" r="1" class="twinkle-2"/>
    <circle cx="220" cy="60" r="0.6"/>
    <circle cx="320" cy="30" r="0.9" class="twinkle-3"/>
    <circle cx="80" cy="120" r="0.7"/>
    <circle cx="180" cy="180" r="0.9" class="twinkle-1"/>
    <circle cx="20" cy="220" r="1.1" class="twinkle-3"/>
    <circle cx="260" cy="240" r="0.7"/>
    <circle cx="350" cy="200" r="0.8" class="twinkle-2"/>
    <circle cx="60" cy="260" r="0.6"/>
    <circle cx="200" cy="100" r="0.5"/>
    <circle cx="160" cy="280" r="0.7" class="twinkle-2"/>
    <circle cx="500" cy="60" r="0.9" class="twinkle-1"/>
    <circle cx="430" cy="160" r="0.7"/>
    <circle cx="560" cy="220" r="0.8" class="twinkle-3"/>
  </g>
</svg>
{% endmacro %}
